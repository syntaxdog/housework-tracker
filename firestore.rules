rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 헬퍼 함수 =====

    function isAuthenticated() {
      return request.auth != null;
    }

    function isHouseMember(houseId) {
      return isAuthenticated()
        && request.auth.uid in get(/databases/$(database)/documents/houses/$(houseId)).data.members;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===== 사용자 문서 =====
    match /users/{userId} {
      // 본인: 읽기/쓰기
      allow write: if isOwner(userId);
      // 같은 가정 멤버가 프로필(이름 등)을 조회할 수 있도록 인증된 사용자 읽기 허용
      allow read: if isAuthenticated();
    }

    // ===== 가정 문서 =====
    match /houses/{houseId} {

      // 읽기: 인증된 사용자 (초대 코드 조회를 위해 필요)
      // 가정 문서 자체는 민감 정보 없음 (name, inviteCode, members)
      // 하위 컬렉션(체크리스트, 기록 등)은 멤버만 접근 가능
      allow read: if isAuthenticated();

      // 생성: 본인이 첫 멤버로 포함, 1명으로 시작
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 1
        && request.resource.data.keys().hasAll(['name', 'inviteCode', 'members', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 50;

      // 업데이트: 멤버 또는 참여하려는 사용자, 최대 2명
      allow update: if isAuthenticated()
        && (request.auth.uid in resource.data.members
            || request.auth.uid in request.resource.data.members)
        && request.resource.data.members.size() <= 2;

      // 삭제 불가
      allow delete: if false;

      // ----- 체크리스트 항목 -----
      match /checklistItems/{itemId} {
        allow read: if isHouseMember(houseId);

        // 생성: 멤버만, 필수 필드 + 값 범위 검증
        allow create: if isHouseMember(houseId)
          && request.resource.data.keys().hasAll(['name', 'points', 'order'])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 50
          && request.resource.data.points is int
          && request.resource.data.points >= 1
          && request.resource.data.points <= 10;

        // 수정: 멤버만, 값 범위 검증
        allow update: if isHouseMember(houseId)
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.points is int
          && request.resource.data.points >= 1
          && request.resource.data.points <= 10;

        // 삭제: 멤버만
        allow delete: if isHouseMember(houseId);
      }

      // ----- 일일 기록 (점수 요약) -----
      match /dailyLogs/{dateId} {
        allow read: if isHouseMember(houseId);
        // 점수 요약은 트랜잭션으로 업데이트 (merge)
        allow write: if isHouseMember(houseId);

        // ----- 개별 완료 기록 -----
        match /completions/{completionId} {
          allow read: if isHouseMember(houseId);

          // 생성: 멤버 + 본인 userId로만 (위조 방지)
          allow create: if isHouseMember(houseId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.keys().hasAll(['itemId', 'itemName', 'points', 'userId', 'userName', 'completedAt'])
            && request.resource.data.points is int
            && request.resource.data.points >= 1;

          // 삭제: 본인이 체크한 항목만 (언체크)
          allow delete: if isAuthenticated()
            && resource.data.userId == request.auth.uid;

          // 수정 불가 (스냅샷 보존)
          allow update: if false;
        }
      }

      // ----- 월간 요약 -----
      match /monthlySummary/{monthId} {
        allow read: if isHouseMember(houseId);
        allow write: if isHouseMember(houseId);
      }
    }
  }
}
